# ============================================================
# Mini Claw 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# --- LLM API (必填至少一组) ---
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=anthropic/claude-sonnet-4-20250514

# --- Telegram Bot (可选) ---
# 从 @BotFather 获取
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF

# --- 飞书 Bot (可选) ---
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=

# --- 企业微信 Bot (可选) ---
# WECOM_CORP_ID=
# WECOM_CORP_SECRET=
# WECOM_WEBHOOK_URL=

# --- 平台配置 ---
MINI_CLAW_PORT=8080
MINI_CLAW_WORKING_DIR=/workspace
# MINI_CLAW_MEMORY_ROOT=data/memory
